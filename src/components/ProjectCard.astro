---
import { getCollection, type CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const { data, slug } = project;
const base = import.meta.env.BASE_URL;
const href = `${base}/projects/${slug}`;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

const dateRange =
  data.endDate
    ? `${fmt(data.startDate)} → ${fmt(data.endDate)}`
    : `${fmt(data.startDate)} → Present`;

const statusClass =
  data.status === 'Active'
    ? 'bg-primary text-white'
    : data.status === 'Shipped'
      ? 'bg-secondary-container text-on-secondary-container'
      : 'bg-surface-dim text-on-surface-variant';

// Resolve project contributors to { member, role } pairs, sorted so Heads render first.
const allMembers = await getCollection('members');
const roleOrder: Record<string, number> = {
  'Project Head': 0,
  'Project Member': 1,
  'Project Contributor': 2,
};
const contributors = data.contributors
  .map(({ slug: memberSlug, role }) => {
    const member = allMembers.find((m) => m.slug === memberSlug);
    return member ? { member, role } : null;
  })
  .filter(
    (c): c is { member: (typeof allMembers)[number]; role: 'Project Head' | 'Project Member' | 'Project Contributor' } =>
      c !== null
  )
  .sort((a, b) => roleOrder[a.role] - roleOrder[b.role]);

const roleRingClass: Record<string, string> = {
  'Project Head': 'ring-amber-400',
  'Project Member': 'ring-primary',
  'Project Contributor': 'ring-slate-300',
};
const roleBadgeClass: Record<string, string> = {
  'Project Head': 'bg-amber-400 text-slate-900',
  'Project Member': 'bg-primary text-white',
  'Project Contributor': 'bg-slate-300 text-slate-800',
};
const roleLetter: Record<string, string> = {
  'Project Head': 'H',
  'Project Member': 'M',
  'Project Contributor': 'C',
};
---

<a
  href={href}
  class="bg-surface-container-lowest rounded-lg ghost-border overflow-hidden group hover:scale-[1.02] transition-all duration-300 flex flex-col shadow-[0px_20px_40px_rgba(25,28,30,0.06)]"
>
  <div class="h-48 relative overflow-hidden bg-surface-container">
    {
      data.image ? (
        <img
          class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105"
          alt={data.title}
          src={base + data.image}
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center bg-surface-container-high">
          <span class="material-symbols-outlined text-primary/20 text-6xl">image</span>
        </div>
      )
    }
    <div class="absolute top-4 left-4 flex gap-2">
      <span
        class={`${statusClass} px-2 py-1 text-[10px] font-bold uppercase tracking-widest rounded`}
        >{data.status}</span
      >
      <span
        class="bg-white/80 backdrop-blur-md text-primary px-2 py-1 text-[10px] font-bold uppercase tracking-widest rounded"
        >{data.category}</span
      >
    </div>
  </div>

  <div class="p-6 flex-1 flex flex-col">
    <h3 class="text-xl font-bold text-on-surface tracking-tight mb-2">
      {data.title}
    </h3>
    <p class="text-sm text-on-surface-variant leading-relaxed mb-4 line-clamp-3">
      {data.description}
    </p>

    {
      data.languages.length > 0 && (
        <div class="flex flex-wrap gap-1 mb-4">
          {data.languages.slice(0, 4).map((lang) => (
            <span class="text-[10px] font-semibold bg-surface-container-low text-on-surface-variant px-2 py-1 rounded">
              {lang}
            </span>
          ))}
          {data.languages.length > 4 && (
            <span class="text-[10px] font-semibold text-outline px-2 py-1">
              +{data.languages.length - 4}
            </span>
          )}
        </div>
      )
    }

    <div
      class="mt-auto pt-4 border-t border-outline-variant/10 flex items-center justify-between"
    >
      <span class="text-[10px] font-mono text-outline uppercase tracking-widest">
        {dateRange}
      </span>
      <span class="material-symbols-outlined text-primary group-hover:translate-x-1 transition-transform text-sm"
        >arrow_forward</span
      >
    </div>

    {
      contributors.length > 0 && (
        <div class="mt-4 pt-4 border-t border-outline-variant/10">
          <div class="flex items-center justify-between gap-3">
            <div class="flex -space-x-2">
              {contributors.slice(0, 6).map(({ member: m, role }) => (
                <div
                  class="relative"
                  title={`${m.data.name} — ${role}`}
                >
                  <div
                    class={`w-9 h-9 rounded-full overflow-hidden bg-surface-container-high ring-2 ring-offset-2 ring-offset-surface-container-lowest ${roleRingClass[role]}`}
                  >
                    {m.data.avatar ? (
                      <img
                        alt={m.data.name}
                        src={m.data.avatar}
                        class="w-full h-full object-cover"
                      />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center text-[10px] font-bold text-on-surface-variant">
                        {m.data.name
                          .split(' ')
                          .map((part) => part[0])
                          .join('')
                          .slice(0, 2)
                          .toUpperCase()}
                      </div>
                    )}
                  </div>
                  <span
                    class={`absolute -bottom-0.5 -right-0.5 w-4 h-4 rounded-full flex items-center justify-center text-[8px] font-black leading-none border border-white ${roleBadgeClass[role]}`}
                    aria-label={role}
                  >
                    {roleLetter[role]}
                  </span>
                </div>
              ))}
              {contributors.length > 6 && (
                <div class="w-9 h-9 rounded-full bg-surface-container-high ring-2 ring-offset-2 ring-offset-surface-container-lowest ring-outline-variant/30 flex items-center justify-center text-[10px] font-bold text-on-surface-variant">
                  +{contributors.length - 6}
                </div>
              )}
            </div>
            <div class="flex items-center gap-2 text-[9px] font-mono font-bold uppercase tracking-widest text-outline">
              <span class="inline-flex items-center gap-1">
                <span class="w-2 h-2 rounded-full bg-amber-400" /> H
              </span>
              <span class="inline-flex items-center gap-1">
                <span class="w-2 h-2 rounded-full bg-primary" /> M
              </span>
              <span class="inline-flex items-center gap-1">
                <span class="w-2 h-2 rounded-full bg-slate-300" /> C
              </span>
            </div>
          </div>
        </div>
      )
    }
  </div>
</a>
