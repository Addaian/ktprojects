---
const base = import.meta.env.BASE_URL;
---

<footer class="bg-slate-50 dark:bg-slate-950 w-full py-12 border-t border-slate-200/15">
  <div
    class="flex flex-col md:flex-row justify-between items-center px-8 max-w-7xl mx-auto gap-6 font-['Plus_Jakarta_Sans'] text-sm uppercase tracking-widest"
  >
    <a href={base + '/'} class="flex items-center gap-2" aria-label="ktprojects home">
      <img src={base + '/logo.png'} alt="" class="h-7 w-auto" />
      <span class="text-xl font-bold lowercase text-primary dark:text-blue-300">ktprojects</span>
    </a>
    <div class="flex gap-8">
      <a
        class="text-slate-400 dark:text-slate-500 hover:text-primary transition-all"
        href={base + '/projects'}>Code</a
      >
      <a
        class="text-slate-400 dark:text-slate-500 hover:text-primary transition-all"
        href={base + '/members'}>Network</a
      >
      <a
        class="text-slate-400 dark:text-slate-500 hover:text-primary transition-all"
        href={base + '/pulse'}>Pulse</a
      >
    </div>
    <div class="text-slate-400 dark:text-slate-500 text-center md:text-right">
      <div>&copy; 2026 KTP Project Committee &middot; Theta Chapter</div>
      <a
        href="mailto:uchicagoktp@gmail.com"
        class="hover:text-primary transition-all normal-case tracking-normal">uchicagoktp@gmail.com</a
      >
    </div>
  </div>
</footer>
