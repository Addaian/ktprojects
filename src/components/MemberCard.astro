---
import type { CollectionEntry } from 'astro:content';

interface Props {
  member: CollectionEntry<'members'>;
}
const { member } = Astro.props;
const { data, slug } = member;
const base = import.meta.env.BASE_URL;
const href = `${base}/members/${slug}`;
const tierClass =
  data.tier === 'Lead'
    ? 'bg-secondary-container text-on-secondary-container'
    : 'bg-outline-variant text-on-surface-variant';
---

<a
  href={href}
  class="bg-surface-container-lowest p-6 rounded-lg shadow-[0px_20px_40px_rgba(25,28,30,0.06)] hover:scale-[1.02] transition-all duration-300 group block"
>
  <div class="relative mb-6">
    <div class="aspect-square w-full rounded-lg overflow-hidden bg-surface-container-high">
      {
        data.avatar && (
          <img
            alt={data.name}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            src={data.avatar}
          />
        )
      }
    </div>
    <span
      class={`${tierClass} absolute top-3 right-3 text-[10px] font-black px-2 py-1 rounded uppercase tracking-tighter shadow`}
      >{data.tier}</span
    >
  </div>
  <div class="mb-6">
    <h3 class="text-lg font-bold text-on-surface group-hover:text-primary transition-colors">
      {data.name}
    </h3>
    <span class="text-xs font-bold text-outline uppercase tracking-widest">{data.role}</span>
  </div>
  {
    data.skills.length > 0 && (
      <div class="space-y-3">
        {data.skills.map((skill) => (
          <div>
            <div class="flex justify-between text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-1">
              <span>{skill.name}</span>
              <span>{skill.level}%</span>
            </div>
            <div class="h-1 bg-surface-container-high w-full rounded-full overflow-hidden">
              <div class="h-full bg-primary" style={`width: ${skill.level}%`} />
            </div>
          </div>
        ))}
      </div>
    )
  }
</a>
