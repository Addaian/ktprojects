---
interface Props {
  active?: 'home' | 'projects' | 'members' | 'about' | 'pulse' | 'join';
}
const { active = 'home' } = Astro.props;
const base = import.meta.env.BASE_URL;

const tabBase =
  'flex items-center gap-2 px-3 py-1.5 font-mono text-xs rounded-t-md transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-primary/50';
const tabClass = (key: string) =>
  active === key
    ? `${tabBase} -mb-[1px] bg-[#f7f8fa] text-slate-800 border border-slate-300/60 border-b-transparent`
    : `${tabBase} text-slate-500 hover:text-slate-700 hover:bg-slate-100/60`;

type Tab = {
  key: string;
  label: string;
  href: string;
  external?: boolean;
};

const tabs: Tab[] = [
  { key: 'home', label: 'home.tsx', href: base + '/' },
  { key: 'projects', label: 'projects.tsx', href: base + '/projects' },
  { key: 'members', label: 'members.tsx', href: base + '/members' },
  { key: 'pulse', label: 'pulse.tsx', href: base + '/pulse' },
  { key: 'about', label: 'about.md', href: base + '/about' },
  { key: 'rush', label: 'rush.sh', href: 'https://uchicagoktp.com', external: true },
];

const activeTab = tabs.find((tab) => tab.key === active) ?? tabs[0];
---

<nav
  class="fixed top-0 w-full z-50 bg-slate-200/75 dark:bg-slate-900/70 backdrop-blur-[24px]"
>
  <div class="flex justify-between items-end h-16 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto gap-4">
    <a
      href={base + '/'}
      class="flex items-center gap-2 pb-3 min-w-0 shrink"
      aria-label="ktprojects home"
    >
      <img src={base + '/logo.png'} alt="" class="h-9 w-auto" />
      <span
        class="text-xl sm:text-2xl font-black lowercase text-primary dark:text-blue-300 font-['Plus_Jakarta_Sans'] tracking-[-0.02em] whitespace-nowrap"
        >ktprojects</span
      >
    </a>
    <div
      class="hidden lg:flex items-end gap-1 border-b border-slate-300/60 flex-1 mx-6 self-stretch pt-0 min-w-0"
    >
      <div class="flex-1"></div>
      {
        tabs.map((tab) => (
          <a
            class={tabClass(tab.key)}
            href={tab.href}
            target={tab.external ? '_blank' : undefined}
            rel={tab.external ? 'noopener' : undefined}
          >
            {tab.external ? (
              <svg
                class="w-3 h-3.5 shrink-0"
                viewBox="0 0 12 14"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
                fill="none"
                stroke="#000"
                stroke-width="1.3"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M2 5 V12 H9 V7.5" />
                <path d="M6 2 H10 V6" />
                <path d="M5 8 L10 2" />
              </svg>
            ) : (
              <svg
                class="w-3 h-3.5 shrink-0"
                viewBox="0 0 12 14"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
              >
                <path
                  d="M1 0.5 L8 0.5 L11 3.5 L11 13.5 L1 13.5 Z"
                  fill="#fbbf24"
                  stroke="#78350f"
                  stroke-width="0.7"
                  stroke-linejoin="round"
                />
                <path
                  d="M8 0.5 L11 3.5 L8 3.5 Z"
                  fill="#fde68a"
                  stroke="#78350f"
                  stroke-width="0.7"
                  stroke-linejoin="round"
                />
              </svg>
            )}
            <span>{tab.label}</span>
          </a>
        ))
      }
    </div>

    <details class="relative lg:hidden pb-3">
      <summary
        class="list-none flex items-center gap-2 px-3 py-2 rounded-md border border-slate-300/70 bg-[#f7f8fa] text-slate-800 font-mono text-xs cursor-pointer select-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-primary/50"
      >
        <span class="inline-flex items-center gap-2 min-w-0">
          <svg
            class="w-3 h-3.5 shrink-0"
            viewBox="0 0 12 14"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              d="M1 0.5 L8 0.5 L11 3.5 L11 13.5 L1 13.5 Z"
              fill="#fbbf24"
              stroke="#78350f"
              stroke-width="0.7"
              stroke-linejoin="round"
            />
            <path
              d="M8 0.5 L11 3.5 L8 3.5 Z"
              fill="#fde68a"
              stroke="#78350f"
              stroke-width="0.7"
              stroke-linejoin="round"
            />
          </svg>
          <span class="whitespace-nowrap">{activeTab.label}</span>
        </span>
        <svg
          class="w-4 h-4 shrink-0 text-slate-500"
          viewBox="0 0 20 20"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path
            d="M5 7.5L10 12.5L15 7.5"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </summary>

      <div class="absolute right-0 top-full mt-2 w-56 rounded-lg border border-slate-300/70 bg-white shadow-xl overflow-hidden">
        <div class="py-2">
          {
            tabs.map((tab) => (
              <a
                class={`flex items-center gap-2 px-4 py-3 font-mono text-xs transition-colors ${
                  active === tab.key
                    ? 'bg-slate-100 text-slate-900'
                    : 'text-slate-600 hover:bg-slate-50 hover:text-slate-800'
                }`}
                href={tab.href}
                target={tab.external ? '_blank' : undefined}
                rel={tab.external ? 'noopener' : undefined}
              >
                {tab.external ? (
                  <svg
                    class="w-3 h-3.5 shrink-0"
                    viewBox="0 0 12 14"
                    xmlns="http://www.w3.org/2000/svg"
                    aria-hidden="true"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M2 5 V12 H9 V7.5" />
                    <path d="M6 2 H10 V6" />
                    <path d="M5 8 L10 2" />
                  </svg>
                ) : (
                  <svg
                    class="w-3 h-3.5 shrink-0"
                    viewBox="0 0 12 14"
                    xmlns="http://www.w3.org/2000/svg"
                    aria-hidden="true"
                  >
                    <path
                      d="M1 0.5 L8 0.5 L11 3.5 L11 13.5 L1 13.5 Z"
                      fill="#fbbf24"
                      stroke="#78350f"
                      stroke-width="0.7"
                      stroke-linejoin="round"
                    />
                    <path
                      d="M8 0.5 L11 3.5 L8 3.5 Z"
                      fill="#fde68a"
                      stroke="#78350f"
                      stroke-width="0.7"
                      stroke-linejoin="round"
                    />
                  </svg>
                )}
                <span>{tab.label}</span>
              </a>
            ))
          }
        </div>
      </div>
    </details>
  </div>
</nav>
