---
interface Props {
  active?: 'home' | 'projects' | 'members' | 'about' | 'pulse' | 'join';
}
const { active = 'home' } = Astro.props;
const base = import.meta.env.BASE_URL;

const tabBase =
  'flex items-center gap-2 px-3 py-1.5 font-mono text-xs rounded-t-md transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-primary/50';
const tabClass = (key: string) =>
  active === key
    ? `${tabBase} -mb-[1px] bg-white text-slate-800 border border-slate-300/60 border-b-transparent`
    : `${tabBase} text-slate-500 hover:text-slate-700 hover:bg-slate-100/60`;

const tabs = [
  { key: 'home', label: 'home.tsx', href: base + '/', ext: 'tsx' },
  { key: 'projects', label: 'projects.tsx', href: base + '/projects', ext: 'tsx' },
  { key: 'members', label: 'members.tsx', href: base + '/members', ext: 'tsx' },
  { key: 'pulse', label: 'pulse.tsx', href: base + '/pulse', ext: 'tsx' },
  { key: 'about', label: 'about.md', href: base + '/about', ext: 'md' },
] as const;

const iconClass = (ext: string) =>
  ext === 'md' ? 'bg-slate-400/80' : 'bg-blue-500/80';
---

<nav
  class="fixed top-0 w-full z-50 bg-white/70 dark:bg-slate-900/70 backdrop-blur-[24px] shadow-[0px_20px_40px_rgba(25,28,30,0.06)]"
>
  <div class="flex justify-between items-end h-16 px-8 max-w-7xl mx-auto">
    <a href={base + '/'} class="flex items-center gap-2 pb-3" aria-label="ktprojects home">
      <img src={base + '/logo.png'} alt="" class="h-9 w-auto" />
      <span
        class="text-2xl font-black lowercase text-primary dark:text-blue-300 font-['Plus_Jakarta_Sans'] tracking-[-0.02em]"
        >ktprojects</span
      >
    </a>
    <div
      class="hidden md:flex items-end gap-1 border-b border-slate-300/60 flex-1 mx-6 self-stretch pt-0"
    >
      <div class="flex-1"></div>
      {
        tabs.map((tab) => (
          <a class={tabClass(tab.key)} href={tab.href}>
            <span class={`w-2.5 h-2.5 rounded-sm ${iconClass(tab.ext)}`} aria-hidden="true" />
            <span>{tab.label}</span>
          </a>
        ))
      }
    </div>
    <a
      href="https://uchicagoktp.com"
      target="_blank"
      rel="noopener"
      class="group inline-flex items-center gap-2 bg-slate-900 border border-slate-700/60 rounded-md pl-3 pr-3 py-1.5 font-mono text-xs text-slate-200 hover:border-slate-500/80 hover:text-white transition-colors shadow-[0px_6px_16px_rgba(15,23,42,0.25)] mb-3 focus-visible:outline focus-visible:outline-2 focus-visible:outline-primary/50"
      aria-label="Join KTP"
    >
      <span class="text-emerald-400">$</span>
      <span>npm run rush</span>
      <span class="nav-join-cursor w-1.5 h-3.5 bg-slate-200 inline-block align-middle" aria-hidden="true"></span>
    </a>
  </div>
</nav>
