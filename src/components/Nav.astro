---
interface Props {
  active?: 'home' | 'projects' | 'members' | 'about' | 'pulse' | 'join';
}
const { active = 'home' } = Astro.props;
const base = import.meta.env.BASE_URL;

const linkClass = (key: string) =>
  active === key
    ? "font-['Plus_Jakarta_Sans'] tracking-[-0.02em] font-bold border-b-2 border-primary pb-1 text-primary dark:text-blue-300 transition-colors duration-200"
    : "font-['Plus_Jakarta_Sans'] tracking-[-0.02em] font-medium text-slate-500 dark:text-slate-400 hover:text-primary-container dark:hover:text-blue-200 transition-colors duration-200";
---

<nav
  class="fixed top-0 w-full z-50 bg-white/70 dark:bg-slate-900/70 backdrop-blur-[24px] shadow-[0px_20px_40px_rgba(25,28,30,0.06)]"
>
  <div class="flex justify-between items-center h-16 px-8 max-w-7xl mx-auto">
    <a
      class="text-2xl font-black lowercase text-primary dark:text-blue-300 font-['Plus_Jakarta_Sans'] tracking-[-0.02em]"
      href={base + '/'}>ktprojects</a
    >
    <div class="hidden md:flex items-center gap-6">
      <a class={linkClass('home')} href={base + '/'}>Home</a>
      <a class={linkClass('projects')} href={base + '/projects'}>Projects</a>
      <a class={linkClass('members')} href={base + '/members'}>Members</a>
      <a class={linkClass('about')} href={base + '/about'}>About</a>
      <a class={linkClass('pulse')} href={base + '/pulse'}>Pulse</a>
    </div>
    <a
      href="https://uchicagoktp.com"
      target="_blank"
      rel="noopener"
      class="bg-gradient-to-br from-primary to-primary-container text-on-primary px-6 py-2 rounded-lg font-bold tracking-tight hover:scale-105 transition-all"
      >Join Us</a
    >
  </div>
</nav>
