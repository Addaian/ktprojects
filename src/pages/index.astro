---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const base = import.meta.env.BASE_URL;
---

<Layout title="ktprojects | Built at UChicago" active="home">
  <main class="pt-16 overflow-hidden">
    <!-- Hero Section -->
    <section class="relative min-h-[921px] flex items-center justify-center px-8">
      <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
        <!-- Scrolling terminal background -->
        <div
          class="absolute inset-0 flex items-start justify-center terminal-mask opacity-[0.18]"
          aria-hidden="true"
        >
          <pre
            class="terminal-scroll font-mono text-[11px] md:text-xs leading-relaxed text-primary whitespace-pre text-left">{`$ git log --oneline
