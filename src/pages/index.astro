  <script is:inline>
    (function () {
      var el = document.getElementById('scramble-word');
      if (!el) return;
      // Skip the scramble if the terminal is not rendered.
      if (el.offsetParent === null) return;
      var phrases = [
        'backend',
        'frontend',
        'game',
        'mobile',
        'data',
        'ai',
        'devtools',
        'systems',
      ];
      var prefersReducedMotion = window.matchMedia(
        '(prefers-reduced-motion: reduce)'
      ).matches;

      if (prefersReducedMotion) {
        var i = 0;
        el.innerText = phrases[0];
        setInterval(function () {
          i = (i + 1) % phrases.length;
          el.innerText = phrases[i];
        }, 3000);
        return;
      }

      function TextScrambler(element) {
        this.el = element;
        this.chars = '!<>-_\\/[]{}—=+*^?#________';
        this.update = this.update.bind(this);
      }
      TextScrambler.prototype.setText = function (newText) {
        var self = this;
        var oldText = this.el.dataset.value || this.el.innerText || '';
        var length = Math.max(oldText.length, newText.length);
        var promise = new Promise(function (resolve) {
          self.resolve = resolve;
        });
        this.queue = [];
        for (var i = 0; i < length; i++) {
          var from = oldText[i] || '';
          var to = newText[i] || '';
          var start = Math.floor(Math.random() * 40);
          var end = start + Math.floor(Math.random() * 40);
          this.queue.push({ from: from, to: to, start: start, end: end });
        }
        cancelAnimationFrame(this.frameRequest);
        this.frame = 0;
        this.update();
        this.el.dataset.value = newText;
        return promise;
      };
      TextScrambler.prototype.update = function () {
        var output = '';
        var complete = 0;
        for (var i = 0; i < this.queue.length; i++) {
          var item = this.queue[i];
          if (this.frame >= item.end) {
            complete++;
            output += item.to;
          } else if (this.frame >= item.start) {
            if (!item.char || Math.random() < 0.28) {
              item.char = this.chars[Math.floor(Math.random() * this.chars.length)];
            }
            output += '<span class="dud">' + item.char + '</span>';
          } else {
            output += item.from;
          }
        }
        this.el.innerHTML = output;
        if (complete === this.queue.length) {
          this.resolve();
        } else {
          this.frameRequest = requestAnimationFrame(this.update);
          this.frame++;
        }
      };

      var fx = new TextScrambler(el);
      var counter = 1; // start at 1 because 'backend' is already shown
      function next() {
        fx.setText(phrases[counter]).then(function () {
          setTimeout(next, 2500);
        });
        counter = (counter + 1) % phrases.length;
      }
      // Small initial delay so the page settles before the first scramble
      setTimeout(next, 1500);
    })();
  </script>

  <script is:inline>
    (function () {
      var win = document.querySelector('[data-hero-window]');
      var handle = document.querySelector('[data-hero-drag-handle]');
      var boundary = document.querySelector('[data-hero-boundary]');
      if (!win || !handle) return;

      var dx = 0;
      var dy = 0;
      var startX = 0;
      var startY = 0;
      var dragging = false;

      function getPoint(event) {
        if (event.touches && event.touches.length) {
          return { x: event.touches[0].clientX, y: event.touches[0].clientY };
        }
        return { x: event.clientX, y: event.clientY };
      }

      function onDown(event) {
        if (event.button !== undefined && event.button !== 0) return;
        var point = getPoint(event);
        dragging = true;
        startX = point.x - dx;
        startY = point.y - dy;
        handle.style.cursor = 'grabbing';
        event.preventDefault();
      }

      function onMove(event) {
        if (!dragging) return;
        var point = getPoint(event);
        var nextDx = point.x - startX;
        var nextDy = point.y - startY;

        if (boundary) {
          var winRect = win.getBoundingClientRect();
          var boundaryRect = boundary.getBoundingClientRect();
          var maxDy = dy + boundaryRect.top - winRect.bottom;
          if (nextDy > maxDy) nextDy = maxDy;
        }

        dx = nextDx;
        dy = nextDy;
        win.style.transform = 'translate(' + dx + 'px, ' + dy + 'px)';
        event.preventDefault();
      }

      function onUp() {
        if (!dragging) return;
        dragging = false;
        handle.style.cursor = '';
      }

      handle.addEventListener('mousedown', onDown);
      window.addEventListener('mousemove', onMove);
      window.addEventListener('mouseup', onUp);

      handle.addEventListener('touchstart', onDown, { passive: false });
      window.addEventListener('touchmove', onMove, { passive: false });
      window.addEventListener('touchend', onUp);
      window.addEventListener('touchcancel', onUp);
    })();
  </script>
