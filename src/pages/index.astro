      var el = document.getElementById('scramble-word');
      if (!el) return;
      // Skip the scramble if the terminal is not rendered.
      if (el.offsetParent === null) return;
      var phrases = [
        'backend',
        'frontend',
        'game',
        'mobile',
        'data',
        'ai',
        'devtools',
        'systems',
      ];
      var prefersReducedMotion = window.matchMedia(
        '(prefers-reduced-motion: reduce)'
      ).matches;

      if (prefersReducedMotion) {
        var i = 0;
        el.innerText = phrases[0];
        setInterval(function () {
          i = (i + 1) % phrases.length;
          el.innerText = phrases[i];
        }, 3000);
        return;
      }

      function TextScrambler(element) {
        this.el = element;
        this.chars = '!<>-_\\/[]{}—=+*^?#________';
        this.update = this.update.bind(this);
      }
      TextScrambler.prototype.setText = function (newText) {
        var self = this;
        var oldText = this.el.dataset.value || this.el.innerText || '';
        var length = Math.max(oldText.length, newText.length);
        var promise = new Promise(function (resolve) {
          self.resolve = resolve;
        });
        this.queue = [];
        for (var i = 0; i < length; i++) {
          var from = oldText[i] || '';
          var to = newText[i] || '';
          var start = Math.floor(Math.random() * 40);
          var end = start + Math.floor(Math.random() * 40);
          this.queue.push({ from: from, to: to, start: start, end: end });
        }
        cancelAnimationFrame(this.frameRequest);
        this.frame = 0;
        this.update();
        this.el.dataset.value = newText;
        return promise;
      };
      TextScrambler.prototype.update = function () {
        var output = '';
        var complete = 0;
        for (var i = 0; i < this.queue.length; i++) {
          var item = this.queue[i];
          if (this.frame >= item.end) {
            complete++;
            output += item.to;
          } else if (this.frame >= item.start) {
            if (!item.char || Math.random() < 0.28) {
              item.char = this.chars[Math.floor(Math.random() * this.chars.length)];
            }
            output += '<span class="dud">' + item.char + '</span>';
          } else {
            output += item.from;
          }
        }
        this.el.innerHTML = output;
        if (complete === this.queue.length) {
          this.resolve();
        } else {
          this.frameRequest = requestAnimationFrame(this.update);
          this.frame++;
        }
      };

      var fx = new TextScrambler(el);
      var counter = 1; // start at 1 because 'backend' is already shown
      function next() {
        fx.setText(phrases[counter]).then(function () {
          setTimeout(next, 2500);
        });
        counter = (counter + 1) % phrases.length;
      }
      // Small initial delay so the page settles before the first scramble
      setTimeout(next, 1500);
    })();
  </script>

  <script is:inline>
    (function () {
      var win = document.querySelector('[data-hero-window]');
      var handle = document.querySelector('[data-hero-drag-handle]');
      var boundary = document.querySelector('[data-hero-boundary]');
      if (!win || !handle) return;

      var dx = 0;
      var dy = 0;
      var startX = 0;
      var startY = 0;
      var dragging = false;

      function getPoint(event) {
        if (event.touches && event.touches.length) {
          return { x: event.touches[0].clientX, y: event.touches[0].clientY };
        }
        return { x: event.clientX, y: event.clientY };
      }

      function onDown(event) {
        if (event.button !== undefined && event.button !== 0) return;
        var point = getPoint(event);
        dragging = true;
        startX = point.x - dx;
        startY = point.y - dy;
        handle.style.cursor = 'grabbing';
        event.preventDefault();
      }

      function onMove(event) {
        if (!dragging) return;
        var point = getPoint(event);
        var nextDx = point.x - startX;
        var nextDy = point.y - startY;

        if (boundary) {
          var winRect = win.getBoundingClientRect();
          var boundaryRect = boundary.getBoundingClientRect();
          var maxDy = dy + boundaryRect.top - winRect.bottom;
          if (nextDy > maxDy) nextDy = maxDy;
        }

        dx = nextDx;
        dy = nextDy;
        win.style.transform = 'translate(' + dx + 'px, ' + dy + 'px)';
        event.preventDefault();
      }

      function onUp() {
        if (!dragging) return;
        dragging = false;
        handle.style.cursor = '';
      }

      handle.addEventListener('mousedown', onDown);
      window.addEventListener('mousemove', onMove);
      window.addEventListener('mouseup', onUp);

      handle.addEventListener('touchstart', onDown, { passive: false });
      window.addEventListener('touchmove', onMove, { passive: false });
      window.addEventListener('touchend', onUp);
      window.addEventListener('touchcancel', onUp);
    })();
  </script>

  <script is:inline>
    (function () {
      var el = document.getElementById('ascii-art');
      if (!el) return;

      var COLS = 40;
      var ROWS = 18;
      var LUMINANCE = '.,-~:;=!*#$@';
      var SCRAMBLE_CHARS = '!<>-_\\/[]{}=+*^?#@$&';

      function emptyCanvas() {
        var c = [];
        for (var r = 0; r < ROWS; r++) {
          c.push(new Array(COLS).fill(' '));
        }
        return c;
      }

      function canvasToString(canvas) {
        var lines = [];
        for (var r = 0; r < ROWS; r++) {
          lines.push(canvas[r].join(''));
        }
        return lines.join('\n');
      }

      function blit(canvas, glyph, startCol, startRow) {
        for (var r = 0; r < glyph.length; r++) {
          var row = glyph[r];
          for (var c = 0; c < row.length; c++) {
            var ch = row[c];
            if (ch === ' ') continue;
            var x = startCol + c;
            var y = startRow + r;
            if (x >= 0 && x < COLS && y >= 0 && y < ROWS) {
              canvas[y][x] = ch;
            }
          }
        }
      }

      // --------- Scene: rotating donut ---------

      function renderDonut(A, B) {
        var output = new Array(COLS * ROWS).fill(' ');
        var zbuffer = new Array(COLS * ROWS).fill(0);
        var R1 = 1, R2 = 2, K2 = 5;
        var K1 = (ROWS * K2 * 3) / (8 * (R1 + R2));
        var cosA = Math.cos(A), sinA = Math.sin(A);
        var cosB = Math.cos(B), sinB = Math.sin(B);
        for (var theta = 0; theta < 6.28; theta += 0.12) {
          var cosT = Math.cos(theta), sinT = Math.sin(theta);
          for (var phi = 0; phi < 6.28; phi += 0.04) {
            var cosP = Math.cos(phi), sinP = Math.sin(phi);
            var circleX = R2 + R1 * cosT;
            var circleY = R1 * sinT;
            var x = circleX * (cosB * cosP + sinA * sinB * sinP) - circleY * cosA * sinB;
            var y = circleX * (sinB * cosP - sinA * cosB * sinP) + circleY * cosA * cosB;
            var z = K2 + cosA * circleX * sinP + circleY * sinA;
            var ooz = 1 / z;
            var xp = Math.floor(COLS / 2 + K1 * ooz * x * 2);
            var yp = Math.floor(ROWS / 2 - K1 * ooz * y);
            var L =
              cosP * cosT * sinB -
              cosA * cosT * sinP -
              sinA * sinT +
              cosB * (cosA * sinT - cosT * sinA * sinP);
            if (L > 0 && xp >= 0 && xp < COLS && yp >= 0 && yp < ROWS) {
              var idx = xp + yp * COLS;
              if (ooz > zbuffer[idx]) {
                zbuffer[idx] = ooz;
                var li = Math.floor(L * 8);
                if (li < 0) li = 0;
                if (li > LUMINANCE.length - 1) li = LUMINANCE.length - 1;
                output[idx] = LUMINANCE[li];
              }
            }
          }
        }
        var result = '';
        for (var r = 0; r < ROWS; r++) {
          result += output.slice(r * COLS, (r + 1) * COLS).join('');
          if (r < ROWS - 1) result += '\n';
        }
        return result;
      }

      // --------- Scene: KTP slide-in ---------
      // Each glyph is 7 chars wide × 5 rows tall; K slides from the left,
      // T drops from the top, P slides from the right. Letters meet at
      // a centered baseline and hold.

      var K_GLYPH = [
        ' _  __ ',
        '| |/ / ',
        "| ' /  ",
        '| . \\  ',
        '|_|\\_\\ ',
      ];
      var T_GLYPH = [
        ' _____ ',
        '|_   _|',
        '  | |  ',
        '  | |  ',
        '  |_|  ',
      ];
      var P_GLYPH = [
        ' ____  ',
        '|  _ \\ ',
        '| |_) |',
        '|  __/ ',
        '|_|    ',
      ];

      var KTP_TARGET_ROW = 6;
      var KTP_TARGET_K = 9;
      var KTP_TARGET_T = 16;
      var KTP_TARGET_P = 23;

      function easeOutCubic(x) {
        return 1 - Math.pow(1 - x, 3);
      }

      function renderKtpIntro(t) {
        var canvas = emptyCanvas();

        // K: slides from off-left (col -8) to target, 0 → 0.38
        var kT = Math.min(1, Math.max(0, t / 0.38));
        var kEased = easeOutCubic(kT);
        var kCol = Math.round(-8 + (KTP_TARGET_K - -8) * kEased);
        if (kT > 0) blit(canvas, K_GLYPH, kCol, KTP_TARGET_ROW);

        // T: drops from off-top (row -6) to target, 0.14 → 0.52
        var tT = Math.min(1, Math.max(0, (t - 0.14) / 0.38));
        var tEased = easeOutCubic(tT);
        var tRow = Math.round(-6 + (KTP_TARGET_ROW - -6) * tEased);
        if (tT > 0) blit(canvas, T_GLYPH, KTP_TARGET_T, tRow);

        // P: slides from off-right (col 40) to target, 0.28 → 0.66
        var pT = Math.min(1, Math.max(0, (t - 0.28) / 0.38));
        var pEased = easeOutCubic(pT);
        var pCol = Math.round(40 + (KTP_TARGET_P - 40) * pEased);
        if (pT > 0) blit(canvas, P_GLYPH, pCol, KTP_TARGET_ROW);

        return canvasToString(canvas);
      }

      // --------- Scene: theta LEGO build ---------
      // A 26-wide × 10-tall theta shape gets stacked cell-by-cell,
      // bottom row first, left-to-right, like laying bricks.

      var THETA_SHAPE = [
        '         ████████         ',
        '      ███        ███      ',
        '    ██              ██    ',
        '   █                  █   ',
        '   █    ██████████    █   ',
        '   █    ██████████    █   ',
        '   █                  █   ',
        '    ██              ██    ',
        '      ███        ███      ',
        '         ████████         ',
      ];

      var THETA_CELLS = (function () {
        var cells = [];
        // Build order: bottom row first, then row above, etc. Within each
        // row, alternate outward from center so it grows symmetrically.
        for (var r = THETA_SHAPE.length - 1; r >= 0; r--) {
          var rowCells = [];
          for (var c = 0; c < THETA_SHAPE[r].length; c++) {
            if (THETA_SHAPE[r][c] !== ' ') rowCells.push([r, c]);
          }
          // Sort by distance from row center so growth is symmetric
          var mid = THETA_SHAPE[r].length / 2;
          rowCells.sort(function (a, b) {
            return Math.abs(a[1] - mid) - Math.abs(b[1] - mid);
          });
          for (var i = 0; i < rowCells.length; i++) cells.push(rowCells[i]);
        }
        return cells;
      })();

      var THETA_START_COL = Math.floor((COLS - THETA_SHAPE[0].length) / 2);
      var THETA_START_ROW = Math.floor((ROWS - THETA_SHAPE.length) / 2);

      function renderThetaLego(t) {
        var canvas = emptyCanvas();
        // Build phase occupies the first 65% of the scene; then hold.
        var buildProgress = Math.min(1, t / 0.65);
        var cellsToShow = Math.floor(buildProgress * THETA_CELLS.length);
        for (var i = 0; i < cellsToShow; i++) {
          var cell = THETA_CELLS[i];
          var y = THETA_START_ROW + cell[0];
          var x = THETA_START_COL + cell[1];
          if (x >= 0 && x < COLS && y >= 0 && y < ROWS) {
            canvas[y][x] = THETA_SHAPE[cell[0]][cell[1]];
          }
        }
        return canvasToString(canvas);
      }

      // --------- Scene: static year block ---------

      function padArt(raw) {
        var lines = raw.split('\n');
        while (lines.length && lines[0].trim() === '') lines.shift();
        while (lines.length && lines[lines.length - 1].trim() === '') lines.pop();
        var maxW = 0;
        for (var i = 0; i < lines.length; i++) {
          if (lines[i].length > maxW) maxW = lines[i].length;
        }
        var leftPad = Math.max(0, Math.floor((COLS - maxW) / 2));
        var centered = lines.map(function (l) {
          var padded = ' '.repeat(leftPad) + l;
          if (padded.length < COLS) padded += ' '.repeat(COLS - padded.length);
          return padded.slice(0, COLS);
        });
        var topPad = Math.max(0, Math.floor((ROWS - centered.length) / 2));
        var out = [];
        for (var t = 0; t < topPad; t++) out.push(' '.repeat(COLS));
        for (var j = 0; j < centered.length; j++) out.push(centered[j]);
        while (out.length < ROWS) out.push(' '.repeat(COLS));
        return out.slice(0, ROWS).join('\n');
      }

      var YEAR_ART = padArt([
        '  ____   ___  _ ____  ',
        ' |___ \\ / _ \\/ |___ \\ ',
        '   __) | | | | | __) |',
        '  / __/| |_| | |/ __/ ',
        ' |_____|\\___/|_|_____|',
      ].join('\n'));

      // --------- Scene orchestration ---------

      var scenes = [
        { type: 'donut', duration: 5000 },
        { type: 'ktp-intro', duration: 3500 },
        { type: 'donut', duration: 4000 },
        { type: 'theta-lego', duration: 3500 },
        { type: 'donut', duration: 4000 },
        { type: 'static', art: YEAR_ART, duration: 2800 },
      ];

      var SCRAMBLE_MS = 650;

      var sceneIndex = 0;
      var phase = 'display';
      var phaseStart = 0;
      var currentFrame = '';
      var scrambleSource = '';
      var scrambleTarget = '';

      function sceneContent(scene, localMs, absoluteNow) {
        if (scene.type === 'donut') {
          // Use absolute time so the donut keeps rotating continuously
          // across scene boundaries.
          var t = absoluteNow / 1000;
          return renderDonut(t * 0.9, t * 0.55);
        }
        if (scene.type === 'ktp-intro') {
          return renderKtpIntro(localMs / scene.duration);
        }
        if (scene.type === 'theta-lego') {
          return renderThetaLego(localMs / scene.duration);
        }
        return scene.art;
      }

      function scrambleFrame(t) {
        var out = '';
        for (var i = 0; i < scrambleTarget.length; i++) {
          var ch = scrambleTarget[i];
          if (ch === '\n') {
            out += '\n';
            continue;
          }
          var src = scrambleSource[i] || ' ';
          var rnd = Math.random();
          if (rnd < t * t) {
            out += ch;
          } else if (rnd < 0.4) {
            out += SCRAMBLE_CHARS[Math.floor(Math.random() * SCRAMBLE_CHARS.length)];
          } else {
            out += src;
          }
        }
        return out;
      }

      function tick(now) {
        if (!phaseStart) phaseStart = now;
        var elapsed = now - phaseStart;
        var scene = scenes[sceneIndex];

        if (phase === 'display') {
          currentFrame = sceneContent(scene, elapsed, now);
          el.textContent = currentFrame;
          if (elapsed >= scene.duration) {
            phase = 'scramble';
            phaseStart = now;
            scrambleSource = currentFrame;
            var nextScene = scenes[(sceneIndex + 1) % scenes.length];
            scrambleTarget = sceneContent(nextScene, 0, now);
          }
        } else {
          var t = Math.min(1, elapsed / SCRAMBLE_MS);
          el.textContent = scrambleFrame(t);
          if (elapsed >= SCRAMBLE_MS) {
            sceneIndex = (sceneIndex + 1) % scenes.length;
            phase = 'display';
            phaseStart = now;
          }
        }

        requestAnimationFrame(tick);
      }

      var prefersReducedMotion = window.matchMedia(
        '(prefers-reduced-motion: reduce)'
      ).matches;

      if (prefersReducedMotion) {
        var staticFrames = [
          renderKtpIntro(1),
          renderThetaLego(1),
          YEAR_ART,
        ];
        var idx = 0;
        el.textContent = staticFrames[0];
        setInterval(function () {
          idx = (idx + 1) % staticFrames.length;
          el.textContent = staticFrames[idx];
        }, 3500);
        return;
      }

      el.textContent = renderDonut(0, 0);
      requestAnimationFrame(tick);
    })();
  </script>
</Layout>
