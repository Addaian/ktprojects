---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const base = import.meta.env.BASE_URL;

// Live stats derived from the project collection.
const statsTotal = projects.length;
const statsActive = projects.filter((p) => p.data.status === 'Active').length;
const statsShipped = projects.filter((p) => p.data.status === 'Shipped').length;
const statsArchived = projects.filter((p) => p.data.status === 'Archived').length;

const uniqueContributors = new Set<string>();
for (const project of projects) {
  for (const contributor of project.data.contributors) {
    uniqueContributors.add(contributor.slug);
  }
}
const statsBuilders = uniqueContributors.size;

const uniqueLanguages = new Set<string>();
for (const project of projects) {
  for (const language of project.data.languages) {
    uniqueLanguages.add(language);
  }
}
const languagesList = Array.from(uniqueLanguages);
const statsLanguagesCount = languagesList.length;
const languagesPreview = languagesList.slice(0, 5).join(', ');
const languagesExtra = languagesList.length > 5 ? ` (+${languagesList.length - 5} more)` : '';

const latestProject = projects.reduce<(typeof projects)[number] | null>((acc, p) => {
  if (!acc) return p;
  return p.data.startDate.valueOf() > acc.data.startDate.valueOf() ? p : acc;
}, null);
const oldestProject = projects.reduce<(typeof projects)[number] | null>((acc, p) => {
  if (!acc) return p;
  return p.data.startDate.valueOf() < acc.data.startDate.valueOf() ? p : acc;
}, null);

const fmtIsoDay = (d: Date) => d.toISOString().slice(0, 10);
const latestLine = latestProject
  ? `${fmtIsoDay(latestProject.data.startDate)}  ${latestProject.data.title}`
  : '—';
const oldestLine = oldestProject
  ? `${fmtIsoDay(oldestProject.data.startDate)}  ${oldestProject.data.title}`
  : '—';
