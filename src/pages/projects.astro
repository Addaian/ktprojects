---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

// Collect unique categories actually in use, in a stable order
const categoryOrder = [
  'Backend',
  'Frontend',
  'Full-Stack',
  'Distributed Systems',
  'AI / ML',
  'Mobile',
  'Infrastructure',
  'DevTools',
  'Data',
  'Other',
];
const usedCategories = Array.from(new Set(projects.map((p) => p.data.category))).sort(
  (a, b) => categoryOrder.indexOf(a) - categoryOrder.indexOf(b)
);
---

<Layout
  title="Projects | KTP Project Committee"
  active="projects"
  bodyClass="bg-background text-on-background selection:bg-primary-container selection:text-white"
>
  <main class="pt-24 pb-20 px-8 max-w-7xl mx-auto technical-grid min-h-screen">
    <header class="mb-12">
      <div
        class="inline-block px-3 py-1 bg-secondary-container text-on-secondary-container text-[10px] font-bold uppercase tracking-widest rounded-full mb-4"
      >
        Archive
      </div>
      <h1 class="text-5xl font-extrabold tracking-tighter text-primary mb-2">
        Project Repository
      </h1>
      <p class="text-on-surface-variant max-w-xl text-lg">
        Every project the KTP Project Committee has built — past, shipped, and in progress.
      </p>
    </header>

    {
      usedCategories.length > 1 && (
        <section class="mb-12 glass-panel p-1 rounded-xl shadow-sm ghost-border">
          <div class="flex flex-wrap items-center gap-2 p-2">
            <div class="flex items-center gap-2 px-4 border-r border-outline-variant/30 mr-2">
              <span class="material-symbols-outlined text-primary text-sm">filter_list</span>
              <span class="text-xs font-bold uppercase tracking-widest text-outline">
                Categories
              </span>
            </div>
            <span class="px-4 py-2 rounded-lg bg-primary text-white text-sm font-bold">
              All ({projects.length})
            </span>
            {usedCategories.map((cat) => {
              const count = projects.filter((p) => p.data.category === cat).length;
              return (
                <span class="px-4 py-2 rounded-lg bg-surface-container-high text-on-surface-variant text-sm font-semibold">
                  {cat} ({count})
                </span>
              );
            })}
          </div>
        </section>
      )
    }

    {
      projects.length === 0 ? (
        <div class="bg-surface-container-low rounded-lg p-16 text-center">
          <span class="material-symbols-outlined text-primary/40 text-6xl mb-4">inventory_2</span>
          <h2 class="text-2xl font-bold text-on-surface mb-2">No projects yet</h2>
          <p class="text-on-surface-variant max-w-md mx-auto">
            The archive is empty. Add your first project via Pages CMS or by creating a markdown
            file in{' '}
            <code class="px-2 py-1 bg-surface-container rounded">src/content/projects/</code>.
          </p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {projects.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
      )
    }
  </main>
</Layout>
