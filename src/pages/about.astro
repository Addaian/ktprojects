---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const leadership = (await getCollection('members', ({ data }) => data.featured)).sort(
  (a, b) => a.data.order - b.data.order
);
const base = import.meta.env.BASE_URL;
---

<Layout title="About | ktprojects" active="about" bodyClass="bg-surface font-body text-on-surface">
  <main class="pt-24 pb-20 max-w-7xl mx-auto px-8">
    <!-- Origin & Mission -->
    <section class="py-20 grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
      <div class="md:col-span-7">
        <span
          class="text-primary font-label text-sm uppercase tracking-widest font-bold"
          >About the Project Committee</span
        >
        <h1
          class="text-5xl md:text-7xl font-headline font-extrabold tracking-tighter text-on-surface mt-4 mb-8"
          aria-label="Kappa Theta Pi. Building at UChicago."
        >
          <span class="word-animate text-primary" style="animation-delay: 0s">Kappa</span>{' '}
          <span class="word-animate text-primary" style="animation-delay: 0.5s">Theta</span>{' '}
          <span class="word-animate text-primary" style="animation-delay: 1s">Pi.</span>
          <br />
          <span class="word-animate" style="animation-delay: 2.5s"
            >Building at <span class="text-[#800000]">UChicago.</span></span
          >
        </h1>
        <div
          class="space-y-6 text-on-surface-variant text-lg leading-relaxed max-w-2xl"
        >
          <p>
            <strong>Kappa Theta Pi</strong> is the first professional technology fraternity in the
            country. Founded on January 10, 2012, KTP exists to build a tech community at
            UChicago's Theta chapter — a place where designers, analysts, computer scientists,
            engineers, artists, entrepreneurs, and economists come together around a shared love of
            technology.
          </p>
          <p>
            The <strong>Project Committee</strong> is where the technical side of KTP lives. It's
            a small group of brothers who ship real software together: tools we actually use,
            products we actually launch, and projects we'd be proud to show a recruiter.
          </p>
          <p>
            The pages that follow are an ongoing archive of what we've built — projects shipped,
            projects in progress, and the brothers behind them.
          </p>
        </div>
      </div>
      <div class="md:col-span-5">
        <div
          class="aspect-square bg-surface-container-low rounded-lg overflow-hidden ghost-border shadow-[0px_20px_40px_rgba(25,28,30,0.06)] group"
        >
          <img
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            alt="University of Chicago building at sunset — Gothic architecture"
            src="https://upload.wikimedia.org/wikipedia/commons/c/cb/University_of_Chicago_building_sunset.jpg"
          />
        </div>
      </div>
    </section>

    <!-- The Five KTP Pillars -->
    <section class="py-20">
      <div class="mb-12">
        <span class="text-primary font-label text-sm uppercase tracking-widest font-bold"
          >The Five KTP Pillars</span
        >
        <h2 class="text-3xl font-headline font-bold tracking-tight mt-2">How we build together</h2>
        <div class="h-1 w-20 bg-primary mt-2"></div>
        <p class="text-on-surface-variant mt-6 max-w-2xl">
          KTP is organized around five pillars. The Project Committee lives inside{' '}
          <strong>Technical Advancement</strong>, but every pillar shapes how we work.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-0 ghost-border rounded-lg overflow-hidden">
        <div
          class="p-8 bg-surface-container-lowest hover:bg-surface-container-low transition-colors"
        >
          <span class="material-symbols-outlined text-primary text-4xl mb-6">code_blocks</span>
          <h3 class="font-headline font-bold text-lg mb-3">Technical Advancement</h3>
          <p class="text-on-surface-variant text-sm">
            Project teams, workshops, and hands-on building. The home of the Project Committee.
          </p>
        </div>
        <div
          class="p-8 bg-surface-container-low hover:bg-surface-container-high transition-colors border-l border-outline-variant/10"
        >
          <span class="material-symbols-outlined text-primary text-4xl mb-6">trending_up</span>
          <h3 class="font-headline font-bold text-lg mb-3">Professional Development</h3>
          <p class="text-on-surface-variant text-sm">
            Interview prep, resume building, mentorship, and private company recruiting events.
          </p>
        </div>
        <div
          class="p-8 bg-surface-container-lowest hover:bg-surface-container-low transition-colors border-l border-outline-variant/10"
        >
          <span class="material-symbols-outlined text-primary text-4xl mb-6">hub</span>
          <h3 class="font-headline font-bold text-lg mb-3">Alumni Mentorship</h3>
          <p class="text-on-surface-variant text-sm">
            A network of alumni at Microsoft, Amazon, Meta, Google, startups, and consulting firms.
          </p>
        </div>
        <div
          class="p-8 bg-surface-container-low hover:bg-surface-container-high transition-colors border-l border-outline-variant/10"
        >
          <span class="material-symbols-outlined text-primary text-4xl mb-6">diversity_3</span>
          <h3 class="font-headline font-bold text-lg mb-3">Social Growth</h3>
          <p class="text-on-surface-variant text-sm">
            The people you meet in KTP become some of your closest friends throughout college.
          </p>
        </div>
        <div
          class="p-8 bg-surface-container-lowest hover:bg-surface-container-low transition-colors border-l border-outline-variant/10"
        >
          <span class="material-symbols-outlined text-primary text-4xl mb-6">school</span>
          <h3 class="font-headline font-bold text-lg mb-3">Academic Support</h3>
          <p class="text-on-surface-variant text-sm">
            A supportive network of the brightest tech minds at UChicago, always available for
            help.
          </p>
        </div>
      </div>
    </section>

    <!-- Leadership -->
    <section class="py-20">
      <div class="flex justify-between items-end mb-16">
        <div>
          <span
            class="text-primary font-label text-sm uppercase tracking-widest font-bold"
            >System Leads</span
          >
          <h2 class="text-4xl font-headline font-bold tracking-tight mt-2">
            Technical Leadership
          </h2>
        </div>
        <div class="hidden md:block text-right">
          <p class="text-outline font-label text-xs uppercase tracking-widest">
            Featured Members: {leadership.length}
          </p>
        </div>
      </div>

      {
        leadership.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
            {leadership.map((member, i) => (
              <a
                href={`${base}/members/${member.slug}`}
                class={`space-y-6 group block ${i === 1 ? 'md:translate-y-12' : ''}`}
              >
                <div class="aspect-[4/5] bg-surface-container-low rounded-lg overflow-hidden ghost-border relative">
                  {member.data.avatar && (
                    <img
                      class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500 scale-105"
                      alt={member.data.name}
                      src={member.data.avatar}
                    />
                  )}
                  <div class="absolute bottom-0 inset-x-0 p-6 bg-gradient-to-t from-primary/80 to-transparent translate-y-full group-hover:translate-y-0 transition-transform duration-500">
                    <p class="text-white text-xs font-label uppercase tracking-widest">
                      {member.data.specialization}
                    </p>
                  </div>
                </div>
                <div>
                  <h4 class="text-2xl font-headline font-bold">{member.data.name}</h4>
                  <p class="text-primary font-label text-sm uppercase tracking-wider font-semibold">
                    {member.data.role}
                  </p>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <p class="text-on-surface-variant">
            No leadership profiles featured yet. Mark a member as{' '}
            <code class="px-2 py-1 bg-surface-container rounded">featured: true</code> in their
            markdown file to show them here.
          </p>
        )
      }
    </section>

    <!-- Timeline -->
    <section
      class="py-24 mt-12 bg-surface-container-low rounded-lg p-12 relative overflow-hidden"
    >
      <div
        class="absolute top-0 right-0 p-12 text-outline-variant/20 text-9xl font-black select-none tracking-tighter hidden md:block"
      >
        HISTORY
      </div>
      <div class="relative z-10 max-w-4xl">
        <div class="mb-16">
          <span class="text-primary font-label text-sm uppercase tracking-widest font-bold"
            >Iterative Progress</span
          >
          <h2 class="text-4xl font-headline font-bold tracking-tight mt-2">
            Evolutionary Milestones
          </h2>
        </div>
        <div class="relative pl-12 border-l-2 border-primary/20 space-y-20">
          <div class="relative">
            <div
              class="absolute -left-[53px] top-1 w-2 h-2 bg-white border-2 border-primary rounded-full"
            >
            </div>
            <div class="flex flex-col md:flex-row md:items-baseline gap-4 md:gap-12">
              <div class="text-primary font-headline font-black text-2xl">2012.01.10</div>
              <div>
                <h4 class="text-xl font-bold mb-2">KTP Founded</h4>
                <p class="text-on-surface-variant max-w-lg">
                  Kappa Theta Pi is founded as the first professional technology fraternity in the
                  country, creating a community where tech-passionate students could belong.
                </p>
              </div>
            </div>
          </div>
          <div class="relative">
            <div
              class="absolute -left-[53px] top-1 w-2 h-2 bg-white border-2 border-primary rounded-full"
            >
            </div>
            <div class="flex flex-col md:flex-row md:items-baseline gap-4 md:gap-12">
              <div class="text-primary font-headline font-black text-2xl">THETA</div>
              <div>
                <h4 class="text-xl font-bold mb-2">UChicago Chapter Chartered</h4>
                <p class="text-on-surface-variant max-w-lg">
                  The Theta chapter of KTP launches at the University of Chicago, bringing the
                  fraternity's professional-tech mission to campus.
                </p>
              </div>
            </div>
          </div>
          <div class="relative">
            <div class="absolute -left-[53px] top-1 w-4 h-4 bg-primary rounded-full -ml-1"></div>
            <div class="flex flex-col md:flex-row md:items-baseline gap-4 md:gap-12">
              <div class="text-primary font-headline font-black text-2xl">PRESENT</div>
              <div>
                <h4 class="text-xl font-bold mb-2">The Project Committee</h4>
                <p class="text-on-surface-variant max-w-lg">
                  Within the Technical Advancement pillar, the Project Committee brings together
                  brothers who want to build real software as a team — tools, products, and
                  portfolios that outlast a single quarter.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
